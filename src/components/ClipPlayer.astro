---
// 切り抜きクリップのプレイヤー。
// カードはサムネイル（先頭フレーム＋再生ボタン＋再生時間チップ）で、
// クリックするとモーダルが開いて大きく再生される。
interface Props {
	url: string;
	label?: string;
}

const { url, label } = Astro.props;
---

<div
	class="group relative overflow-hidden rounded-2xl border-3 border-edge bg-ink shadow-pop-sm"
	data-clip-player
>
	{/* biome-ignore lint/a11y/useMediaCaption: 字幕は動画に焼き込み済み */}
	<video
		src={url}
		preload="metadata"
		playsinline
		muted
		tabindex="-1"
		class="pointer-events-none aspect-[9/16] w-full object-cover"
	/>
	<button
		type="button"
		data-clip-overlay
		aria-label={`${label ?? "クリップ"}を再生`}
		class="absolute inset-0 z-10 flex cursor-pointer items-center justify-center"
	>
		<span
			class="flex h-20 w-20 items-center justify-center rounded-full border-3 border-edge bg-tangerine shadow-pop-sm transition-transform duration-150 ease-out-quart group-hover:-translate-y-0.5 group-hover:scale-105"
		>
			<svg
				viewBox="0 0 24 24"
				class="ml-1 h-9 w-9 text-[rgb(29,26,46)]"
				fill="currentColor"
				aria-hidden="true"
			>
				<path d="M8 5v14l11-7z"></path>
			</svg>
		</span>
	</button>
	<span
		data-clip-duration
		class="pointer-events-none absolute right-3 top-3 z-10 rounded-full border-3 border-edge bg-surface px-2.5 py-0.5 font-mono text-xs shadow-pop-xs"
		hidden></span>

	<dialog
		data-clip-modal
		aria-label={label ?? "切り抜きクリップ"}
		class="m-auto bg-transparent p-0"
	>
		<div class="relative">
			{/* biome-ignore lint/a11y/useMediaCaption: 字幕は動画に焼き込み済み */}
			<video
				src={url}
				preload="none"
				playsinline
				controls
				class="mx-auto aspect-[9/16] max-h-[82vh] w-auto max-w-[calc(100vw-4rem)] rounded-2xl border-3 border-edge bg-ink shadow-pop"
			/>
			<button
				type="button"
				data-clip-close
				aria-label="閉じる"
				class="btn-pop absolute -right-4 -top-4 grid h-11 w-11 place-items-center rounded-full bg-surface font-display text-lg leading-none"
			>
				✕
			</button>
			<div class="mx-auto mt-4 flex w-fit max-w-[calc(100vw-2rem)] items-center gap-3">
				{
					label && (
						<p class="min-w-0 truncate rounded-full border-3 border-edge bg-surface px-4 py-1.5 text-sm font-bold shadow-pop-xs">
							{label}
						</p>
					)
				}
				<button
					type="button"
					data-clip-download
					class="btn-pop flex shrink-0 items-center gap-1.5 rounded-full bg-tangerine px-4 py-1.5 text-sm font-bold text-[rgb(29,26,46)]"
				>
					<svg
						viewBox="0 0 24 24"
						class="h-4 w-4"
						fill="none"
						stroke="currentColor"
						stroke-width="2.5"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M12 4v11m0 0 -4.5-4.5M12 15l4.5-4.5M4 20h16"></path>
					</svg>
					保存
				</button>
			</div>
		</div>
	</dialog>
</div>

<style>
	dialog[data-clip-modal]::backdrop {
		background: rgb(29 26 46 / 0.85);
	}
	dialog[data-clip-modal][open] {
		animation: clip-modal-in 200ms cubic-bezier(0.23, 1, 0.32, 1) both;
	}
	@keyframes clip-modal-in {
		from {
			opacity: 0;
			transform: scale(0.96);
		}
	}
</style>

<script>
	const formatDuration = (seconds: number) => {
		const m = Math.floor(seconds / 60);
		const s = Math.round(seconds % 60);
		return `${m}:${String(s).padStart(2, "0")}`;
	};

	// View Transitions でのページ遷移後も初期化されるよう astro:page-load で毎回呼ぶ
	const init = () => {
		for (const root of document.querySelectorAll<HTMLElement>(
			"[data-clip-player]",
		)) {
			if (root.dataset.clipInit) continue;
			root.dataset.clipInit = "true";

			const thumb = root.querySelector("video");
			const overlay = root.querySelector<HTMLElement>("[data-clip-overlay]");
			const duration = root.querySelector<HTMLElement>("[data-clip-duration]");
			const modal = root.querySelector("dialog");
			const modalVideo = modal?.querySelector("video");
			const closeButton = modal?.querySelector<HTMLElement>(
				"[data-clip-close]",
			);
			if (!thumb || !overlay || !duration || !modal || !modalVideo) continue;

			const showDuration = () => {
				if (!Number.isFinite(thumb.duration)) return;
				duration.textContent = formatDuration(thumb.duration);
				duration.hidden = false;
			};
			if (thumb.readyState >= 1) showDuration();
			thumb.addEventListener("loadedmetadata", showDuration);

			// 配信側の一時的なエラーで黒画面のまま止まることがあるので、
			// 再生失敗・メディアエラー時は一度だけ読み直して再試行する
			let errorRetried = false;
			const playFromStart = () => {
				if (modalVideo.readyState >= 1) modalVideo.currentTime = 0;
				modalVideo.play().catch(() => {
					modalVideo.load();
					modalVideo.play().catch(() => {});
				});
			};
			modalVideo.addEventListener("error", () => {
				if (!modal.open || errorRetried) return;
				errorRetried = true;
				modalVideo.load();
				modalVideo.play().catch(() => {});
			});

			overlay.addEventListener("click", () => {
				errorRetried = false;
				modal.showModal();
				playFromStart();
			});

			// ダウンロード: cross-origin なので blob 経由で保存する（R2側でCORS許可済み）。
			// fetch できない場合は新規タブで開くフォールバック
			const downloadButton = modal.querySelector<HTMLButtonElement>(
				"[data-clip-download]",
			);
			downloadButton?.addEventListener("click", async () => {
				const url = modalVideo.getAttribute("src");
				if (!url || downloadButton.disabled) return;
				const filename =
					new URL(url, location.href).pathname.split("/").pop() || "clip.mp4";
				downloadButton.disabled = true;
				try {
					// CORS対応前にキャッシュされたレスポンス（ACAOヘッダ無し）に
					// ヒットすると失敗するため、キャッシュは常に迂回する
					const res = await fetch(url, { cache: "no-store" });
					if (!res.ok) throw new Error(String(res.status));
					const blobUrl = URL.createObjectURL(await res.blob());
					const a = document.createElement("a");
					a.href = blobUrl;
					a.download = filename;
					a.click();
					setTimeout(() => URL.revokeObjectURL(blobUrl), 10_000);
				} catch {
					window.open(url, "_blank", "noopener");
				} finally {
					downloadButton.disabled = false;
				}
			});

			// Esc・✕・背景クリックのどれで閉じても close イベントに集約される
			modal.addEventListener("close", () => {
				modalVideo.pause();
			});
			closeButton?.addEventListener("click", () => {
				modal.close();
			});
			modal.addEventListener("click", (e) => {
				if (e.target === modal) modal.close();
			});
		}
	};

	init();
	document.addEventListener("astro:page-load", init);
</script>
