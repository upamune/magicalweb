---

{
	variant === "chips" ? (
		<ul class="flex flex-wrap gap-3">
			{platforms.map((platform) => (
				<li>
					<a
						href={platform.url}
						target="_blank"
						rel="noopener noreferrer"
						class="btn-pop inline-flex items-center gap-2 rounded-full bg-surface px-4 py-2 text-sm font-bold"
					>
						<svg
							viewBox="0 0 24 24"
							class="h-4 w-4"
							fill="currentColor"
							style={`color: ${platform.color}`}
							aria-hidden="true"
						>
							<path d={platform.path} />
						</svg>
						{platform.name}
					</a>
				</li>
			))}
		</ul>
	) : (
		<ul class="flex items-center gap-2">
			{platforms.map((platform) => (
				<li>
					<a
						href={platform.url}
						target="_blank"
						rel="noopener noreferrer"
						class="btn-pop grid h-10 w-10 place-items-center rounded-full bg-surface"
						aria-label={platform.name}
						style={`color: ${platform.color}`}
					>
						<svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="currentColor" aria-hidden="true">
							<path d={platform.path} />
						</svg>
					</a>
				</li>
			))}
		</ul>
	)
}
