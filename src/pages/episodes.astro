---
import EpisodeList from "../components/EpisodeList";
import Footer from "../components/Footer.astro";
import Header from "../components/Header";
import Layout from "../layouts/Layout.astro";
import { getLatestEpisodes, toEpisodeListItem } from "../utils/rss";

const episodes = await getLatestEpisodes(1000);
const listItems = episodes.map(toEpisodeListItem);
---

<Layout
	title="エピソード一覧 - マヂカル.fm"
	description="マヂカル.fmの全エピソード一覧です。関西人のプロダクトマネージャー@michiru_daと関西人(?)のソフトウェアエンジニアの@upamuneがほぼ週2で配信する雑談Podcastをお楽しみください。"
	type="website"
>
	<Header client:load />

	<section class="dotted border-b-3 border-edge bg-lilac">
		<div class="mx-auto max-w-5xl px-5 py-12 sm:py-16">
			<span class="inline-block -rotate-2 rounded-full border-3 border-edge bg-sun px-4 py-1.5 font-display text-xs text-[rgb(29,26,46)] shadow-pop-sm">
				全{listItems.length}話
			</span>
			<h1
				class="mt-5 font-display text-4xl tracking-tight text-[rgb(29,26,46)] sm:text-5xl"
				style="text-shadow: 4px 4px 0 rgb(255 255 255 / 0.55)"
			>
				エピソード一覧
			</h1>
			<p class="mt-4 max-w-xl text-sm font-bold leading-relaxed text-[rgb(29,26,46)]/80">
				カードの再生ボタンからその場で聴けます。タイトルを押すと詳細ページへ。
			</p>
		</div>
	</section>

	<div class="mx-auto max-w-5xl px-5 py-10 sm:py-12">
		<EpisodeList
			client:load
			episodes={listItems.slice(0, 24)}
			total={listItems.length}
			searchable
		/>
	</div>

	<Footer />
</Layout>
