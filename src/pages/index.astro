---
import ClipPlayer from "../components/ClipPlayer.astro";
import EpisodeList from "../components/EpisodeList";
import Footer from "../components/Footer.astro";
import Header from "../components/Header";
import Hosts from "../components/Hosts.astro";
import MerchGrid from "../components/MerchGrid.astro";
import PlatformLinks from "../components/PlatformLinks.astro";
import PlayButton from "../components/PlayButton";
import Layout from "../layouts/Layout.astro";
import { getPublishedClips } from "../utils/clips";
import { getLatestEpisodes, toEpisodeListItem } from "../utils/rss";

const episodes = await getLatestEpisodes(5);
const listItems = episodes.map(toEpisodeListItem);
const latest = listItems[0];

// 最新クリップ3本（公開済みエピソードのものだけ表示する）
const latestClips = (await getPublishedClips()).slice(0, 3);

const tickerItems = [
	"マヂカル.fm",
	`#${latest?.number} 公開!`,
	"ほぼ週2で配信中",
	"雑談100%",
	"お便り募集中 #magicalfm",
];
---

<Layout title="マヂカル.fm - ほぼ週2の雑談ポッドキャスト">
	<Header client:load />

	<!-- Hero（ライラック） -->
	<section class="dotted border-b-3 border-edge bg-lilac">
		<div class="mx-auto max-w-5xl px-5 pb-16 pt-12 text-center sm:pb-20 sm:pt-16">
			<div class="rise rise-1 flex flex-wrap items-center justify-center gap-3">
				<span class="float-a inline-block rounded-full border-3 border-edge bg-sun px-4 py-1.5 font-display text-sm text-[rgb(29,26,46)] shadow-pop-sm">ほぼ週2!</span>
				<span class="float-b inline-block rounded-full border-3 border-edge bg-lime px-4 py-1.5 font-display text-sm text-[rgb(29,26,46)] shadow-pop-sm">雑談100%</span>
			</div>

			<h1
				class="rise rise-2 mt-8 font-display text-5xl leading-[1.15] tracking-tight text-[rgb(29,26,46)] sm:text-7xl"
				style="text-shadow: 4px 4px 0 rgb(255 255 255 / 0.55)"
			>
				マヂカル<span class="text-tangerine" style="-webkit-text-stroke: 2px rgb(29 26 46)">.fm</span>
			</h1>

			<div class="rise rise-3 mx-auto mt-8 max-w-xl rounded-3xl border-3 border-edge bg-surface px-6 py-5 shadow-pop">
				<p class="leading-relaxed">
					関西人のプロダクトマネージャー
					<a
						href="https://x.com/applism118"
						target="_blank"
						rel="noopener noreferrer"
						class="font-bold text-tangerine underline decoration-[3px] underline-offset-4 transition-colors duration-150 hover:text-candy">@michiru_da</a
					>
					と、関西人(?)のソフトウェアエンジニア
					<a
						href="https://x.com/upamune"
						target="_blank"
						rel="noopener noreferrer"
						class="font-bold text-tangerine underline decoration-[3px] underline-offset-4 transition-colors duration-150 hover:text-candy">@upamune</a
					>
					が、ほぼ週2でお届けする雑談ポッドキャスト。
				</p>
			</div>

			<div class="rise rise-4 mt-8 flex flex-wrap items-center justify-center gap-4">
				{
					latest && (
						<PlayButton
							client:load
							episodeNumber={latest.number}
							episodeSlug={latest.slug}
							episodeTitle={latest.title}
							audioUrl={latest.audioUrl}
							label={`最新回 #${latest.number} を聴く`}
						/>
					)
				}
				<a
					href="/episodes"
					class="btn-pop inline-flex items-center gap-2 rounded-full bg-surface px-6 py-3.5 font-bold"
				>
					エピソード一覧
					<span aria-hidden="true">→</span>
				</a>
			</div>

			<div class="rise rise-4 mt-10 flex justify-center">
				<PlatformLinks variant="chips" />
			</div>
		</div>
	</section>

	<!-- ティッカー帯 -->
	<div class="ticker border-b-3 border-edge bg-sun py-2 font-display text-sm text-[rgb(29,26,46)]" aria-hidden="true">
		{
			[0, 1].map(() => (
				<div>
					{[...tickerItems, ...tickerItems].map((item) => (
						<span class="flex items-center gap-3 px-3">
							{item}
							<span class="text-tangerine">✦</span>
						</span>
					))}
				</div>
			))
		}
	</div>

	<!-- 切り抜きクリップ（サン） -->
	{
		latestClips.length > 0 && (
			<section
				id="clips"
				class="dotted border-b-3 border-edge bg-sun"
				aria-label="切り抜きクリップ"
			>
				<div class="mx-auto max-w-5xl px-5 py-16 sm:py-20">
					<div class="mb-8 flex flex-wrap items-end justify-between gap-4">
						<h2 class="font-display text-3xl text-[rgb(29,26,46)]">
							🎬 最新切り抜きクリップ
						</h2>
						<a
							href="/clips"
							class="btn-pop rounded-full bg-surface px-5 py-2 text-sm font-bold"
						>
							ぜんぶ見る →
						</a>
					</div>
					<div class="grid gap-6 sm:grid-cols-3">
						{latestClips.map((clip) => (
							<div class="rounded-3xl border-3 border-edge bg-surface p-4 shadow-pop">
								<ClipPlayer url={clip.url} label={clip.label} />
								<div class="mt-4 flex items-center gap-3">
									<a
										href={`/ep/${clip.episode?.slug}`}
										class="btn-pop inline-block shrink-0 rounded-full bg-sun px-3 py-1 font-display text-xs text-[rgb(29,26,46)]"
									>
										#{clip.episodeNumber}
									</a>
									<p class="truncate text-sm font-bold">
										{clip.label ?? clip.episode?.title}
									</p>
								</div>
							</div>
						))}
					</div>
				</div>
			</section>
		)
	}

	<!-- 最新エピソード（ライム） -->
	<section id="episodes" class="border-b-3 border-edge bg-lime">
		<div class="mx-auto max-w-5xl px-5 py-16 sm:py-20">
			<div class="mb-8 flex flex-wrap items-end justify-between gap-4">
				<h2 class="font-display text-3xl text-[rgb(29,26,46)]">最新エピソード</h2>
				<a
					href="/episodes"
					class="btn-pop rounded-full bg-surface px-5 py-2 text-sm font-bold"
				>
					ぜんぶ見る →
				</a>
			</div>
			<EpisodeList client:load episodes={listItems} />
		</div>
	</section>

	<!-- パーソナリティ（タンジェリン） -->
	<section id="hosts" class="dotted border-b-3 border-edge bg-tangerine">
		<div class="mx-auto max-w-5xl px-5 py-16 sm:py-20">
			<h2 class="mb-8 font-display text-3xl text-[rgb(29,26,46)]">パーソナリティ</h2>
			<Hosts />
		</div>
	</section>

	<!-- お便り（スカイ） -->
	<section class="border-b-3 border-edge bg-sky">
		<div class="mx-auto max-w-5xl px-5 py-16 text-center sm:py-20">
			<div class="mx-auto max-w-2xl -rotate-1 rounded-3xl border-3 border-edge bg-surface px-6 py-12 shadow-pop sm:py-14">
				<h2 class="font-display text-3xl text-ink">お便り、待ってます 📮</h2>
				<p class="mx-auto mt-4 max-w-md text-sm leading-relaxed text-muted">
					感想・質問・お悩み、なんでもどうぞ。X のハッシュタグ
					<a
						href="https://x.com/hashtag/magicalfm"
						target="_blank"
						rel="noopener noreferrer"
						class="font-bold text-tangerine underline decoration-[3px] underline-offset-4">#magicalfm</a
					>
					でのポストも全部読んでいます。
				</p>
				<div class="mt-8 flex flex-wrap justify-center gap-3">
					<a
						href="https://go.magical.fm/hello"
						target="_blank"
						rel="noopener noreferrer"
						class="btn-pop inline-flex items-center gap-2 rounded-full bg-tangerine px-7 py-3 font-bold text-[rgb(29,26,46)]"
					>
						お便りフォーム
					</a>
					<a
						href="https://marshmallow-qa.com/xno94s1ortkw63w?t=e1P9wQ"
						target="_blank"
						rel="noopener noreferrer"
						class="btn-pop inline-flex items-center gap-2 rounded-full bg-surface px-7 py-3 font-bold"
					>
						マシュマロを投げる
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- グッズ（キャンディピンク） -->
	<section id="merch" class="dotted bg-candy">
		<div class="mx-auto max-w-5xl px-5 py-16 sm:py-20">
			<div class="mb-10 flex flex-wrap items-end justify-between gap-4">
				<h2 class="font-display text-3xl text-[rgb(29,26,46)]">グッズ</h2>
				<a
					href="https://suzuri.jp/magicalfm"
					target="_blank"
					rel="noopener noreferrer"
					class="btn-pop rounded-full bg-surface px-5 py-2 text-sm font-bold"
				>
					SUZURIで見る →
				</a>
			</div>
			<MerchGrid />
		</div>
	</section>

	<Footer />
</Layout>
