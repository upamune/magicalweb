---
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header";
import Hosts from "../../components/Hosts.astro";
import PlayButton from "../../components/PlayButton";
import SeekFromQuery from "../../components/SeekFromQuery";
import Layout from "../../layouts/Layout.astro";
import {
	getAllEpisodeSlugs,
	getEpisodeBySlug,
	getEpisodeDisplayTitle,
	getEpisodeSlug,
	getLatestEpisodes,
} from "../../utils/rss";

export async function getStaticPaths() {
	const slugs = await getAllEpisodeSlugs();
	return slugs.map((slug) => ({
		params: { slug },
	}));
}

const { slug } = Astro.params;
const episode = await getEpisodeBySlug(slug ?? "");

if (!episode) {
	return Astro.redirect("/404");
}

const episodeSlug = getEpisodeSlug(episode);
const ogImage = `/og/ep-${episodeSlug}.png`;

// 前後のエピソード（配列は新しい順）
const allEpisodes = await getLatestEpisodes(1000);
const index = allEpisodes.findIndex((ep) => ep.number === episode.number);
const newerEpisode = index > 0 ? allEpisodes[index - 1] : null;
const olderEpisode =
	index < allEpisodes.length - 1 ? allEpisodes[index + 1] : null;

const displayTitle = getEpisodeDisplayTitle(episode);

const shareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(
	`${episode.title} を聴いています | マヂカル.fm`,
)}&url=${encodeURIComponent(`https://www.magical.fm/ep/${episodeSlug}`)}&hashtags=magicalfm`;

const publishedIso = new Date(
	episode.pubDate.replace(/年|月/g, "-").replace("日", ""),
).toISOString();

// 構造化データ（Google ポッドキャスト/リッチリザルト向け）
const jsonLd = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "PodcastEpisode",
	url: `https://www.magical.fm/ep/${episodeSlug}`,
	name: episode.title,
	episodeNumber: episode.number,
	datePublished: publishedIso,
	description: episode.description.replace(/<[^>]*>/g, "").slice(0, 300),
	associatedMedia: {
		"@type": "MediaObject",
		contentUrl: episode.audioUrl,
	},
	partOfSeries: {
		"@type": "PodcastSeries",
		name: "マヂカル.fm",
		url: "https://www.magical.fm",
	},
});
---

<Layout
	title={`${episode.title} - マヂカル.fm`}
	description={episode.description.replace(/<[^>]*>/g, "").slice(0, 200) + "..."}
	image={ogImage}
	type="article"
	publishedTime={publishedIso}
>
	<script type="application/ld+json" set:html={jsonLd} is:inline />
	<Header client:load />
	<SeekFromQuery
		client:load
		episodeNumber={episode.number}
		episodeSlug={episodeSlug}
		episodeTitle={displayTitle}
		audioUrl={episode.audioUrl}
	/>

	<!-- ヘッダー（スカイ） -->
	<section class="dotted border-b-3 border-edge bg-sky">
		<div class="mx-auto max-w-3xl px-5 py-10 sm:py-14">
			<a
				href="/episodes"
				class="btn-pop inline-flex items-center gap-2 rounded-full bg-surface px-4 py-1.5 text-xs font-bold"
			>
				<span aria-hidden="true">←</span>
				エピソード一覧
			</a>

			<div class="mt-6 flex flex-wrap items-center gap-3">
				<span class="inline-block -rotate-2 rounded-xl border-3 border-edge bg-sun px-3.5 py-1.5 font-display text-sm text-[rgb(29,26,46)] shadow-pop-xs">
					#{episode.number}
				</span>
				<span class="text-sm font-bold text-[rgb(29,26,46)]/80">{episode.pubDate}</span>
			</div>
			<h1
				class="mt-4 font-display text-2xl leading-snug tracking-tight text-[rgb(29,26,46)] sm:text-4xl"
				style="text-shadow: 3px 3px 0 rgb(255 255 255 / 0.55)"
			>
				{displayTitle}
			</h1>

			<div class="mt-8 flex flex-wrap items-center gap-3">
				<PlayButton
					client:load
					episodeNumber={episode.number}
					episodeSlug={episodeSlug}
					episodeTitle={displayTitle}
					audioUrl={episode.audioUrl}
				/>
				<a
					href={shareUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="btn-pop inline-flex items-center gap-2 rounded-full bg-surface px-6 py-3.5 text-sm font-bold"
				>
					<svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="currentColor" aria-hidden="true">
						<path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"></path>
					</svg>
					ポストする
				</a>
			</div>
		</div>
	</section>

	<article class="mx-auto max-w-3xl px-5 pt-10 sm:pt-12">
		<div class="rounded-3xl border-3 border-edge bg-surface p-6 shadow-pop sm:p-8">
			<div
				class="prose prose-stone max-w-none dark:prose-invert prose-p:leading-relaxed prose-p:text-ink/90 prose-a:font-bold prose-a:text-tangerine prose-a:decoration-[2px] prose-a:underline-offset-4 prose-strong:text-ink"
				set:html={episode.description}
			/>
		</div>

		{/* 前後のエピソード */}
		<nav class="mt-10 grid gap-4 sm:grid-cols-2" aria-label="前後のエピソード">
			{
				olderEpisode ? (
					<a
						href={`/ep/${getEpisodeSlug(olderEpisode)}`}
						class="btn-pop group rounded-2xl bg-surface p-5"
					>
						<p class="font-display text-[11px] tracking-widest text-muted">
							← 前の回 #{olderEpisode.number}
						</p>
						<p class="mt-2 truncate text-sm font-bold underline decoration-transparent decoration-[3px] underline-offset-4 transition-[text-decoration-color] duration-150 group-hover:decoration-tangerine">
							{getEpisodeDisplayTitle(olderEpisode)}
						</p>
					</a>
				) : (
					<span />
				)
			}
			{
				newerEpisode && (
					<a
						href={`/ep/${getEpisodeSlug(newerEpisode)}`}
						class="btn-pop group rounded-2xl bg-surface p-5 text-right"
					>
						<p class="font-display text-[11px] tracking-widest text-muted">
							次の回 #{newerEpisode.number} →
						</p>
						<p class="mt-2 truncate text-sm font-bold underline decoration-transparent decoration-[3px] underline-offset-4 transition-[text-decoration-color] duration-150 group-hover:decoration-tangerine">
							{getEpisodeDisplayTitle(newerEpisode)}
						</p>
					</a>
				)
			}
		</nav>

		<section class="mt-12">
			<h2 class="mb-5 font-display text-lg">パーソナリティ</h2>
			<Hosts compact />
		</section>
	</article>

	<Footer />
</Layout>
